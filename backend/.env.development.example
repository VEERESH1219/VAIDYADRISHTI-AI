NODE_ENV=development
PORT=3001
APP_VERSION=1.1.0
SERVICE_NAME=vaidyadrishti-backend
LOG_LEVEL=debug

JWT_SECRET=replace-with-dev-secret
MASTER_ADMIN_KEY=replace-with-dev-master-key

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=vaidyadrishti
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=

REDIS_URL=redis://127.0.0.1:6379

RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_PUBLIC_MAX=120
RATE_LIMIT_TENANT_MAX=300
GLOBAL_REQUEST_TIMEOUT_MS=45000

WORKER_CONCURRENCY=2
JOB_MAX_ATTEMPTS=2
JOB_BACKOFF_MS=2000

MODEL_PROVIDER=ollama
VISION_PROVIDER=ollama
OLLAMA_ENDPOINT=http://127.0.0.1:11434

# Observability
DB_SLOW_QUERY_MS=500
RESOURCE_MONITOR_INTERVAL_MS=30000
RESOURCE_HEAP_WARN_MB=768
RESOURCE_RSS_WARN_MB=1024
EVENT_LOOP_DELAY_WARN_MS=200

# Performance tuning
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONN_TIMEOUT_MS=5000
# WORKER_CONCURRENCY controls worker parallelism
# RATE_LIMIT_PUBLIC_MAX and RATE_LIMIT_TENANT_MAX control traffic shaping

# Load testing (non-production only)
LOAD_BASE_URL=http://127.0.0.1:3001
LOAD_CONCURRENCY_LEVELS=10,50,100,200
LOAD_DURATION_SEC=20
LOAD_PIPELINING=1
LOAD_JWT_TOKEN=
LOAD_TEST_ALLOW_PROD=false
