{
  "name": "medmap-ai-backend",
  "version": "1.0.0",
  "description": "VAIDYADRISHTI AI — Intelligent Medicine Extraction and Matching System (Backend)",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "dev": "node server.js",
    "start": "node server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "import": "node scripts/importMedicines.js",
    "embeddings": "node scripts/generateEmbeddings.js",
    "ollama:setup": "node scripts/setup-ollama.js",
    "ollama:serve": "node scripts/start-ollama.js",
    "ollama:pull": "node scripts/pull-models.js",
    "paddle:install": "pip install \"paddleocr<3.0\" paddlepaddle",
    "db:setup": "node scripts/setupDb.js",
    "db:import": "node scripts/importToPostgres.js"
  },
  "keywords": [
    "medicine",
    "ocr",
    "nlp",
    "prescription"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.97.0",
    "cors": "^2.8.6",
    "csv-parse": "^6.1.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "ollama": "^0.6.3",
    "openai": "^6.22.0",
    "p-limit": "^7.3.0",
    "pg": "^8.19.0",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "vitest": "^4.0.18"
  }
}
