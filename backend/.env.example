# ─── Server ────────────────────────────────────────────────
PORT=3001

# ═══════════════════════════════════════════════════════════
# VISION OCR PROVIDER — PICK THE BEST OPTION FOR YOU
# ═══════════════════════════════════════════════════════════
#
# ★ OPTION 1 — Google Cloud Vision (BEST quality, free 1000/month)
#   Purpose-built OCR engine, handles handwriting better than any LLM.
#   Setup (2 minutes, no billing needed for free tier):
#     1. Go to: https://console.cloud.google.com
#     2. Create a project → Enable "Cloud Vision API"
#     3. Go to APIs & Services → Credentials → Create API Key
#     4. Set: VISION_PROVIDER=google
#             GOOGLE_VISION_API_KEY=AIza...
#
# ★ OPTION 2 — Gemini Flash 2.0 (free 1500/day, very fast, excellent quality)
#   Already in the codebase. Get a FREE key in 30 seconds:
#     1. Go to: https://aistudio.google.com/apikey
#     2. Click "Create API key" — no billing required
#     3. Set: VISION_PROVIDER=gemini
#             GEMINI_API_KEY=AIza...
#
# ✓ OPTION 3 — Ollama (100% local, no API key, slower)
#   Set: VISION_PROVIDER=ollama
#   Pull best model: ollama pull llava-llama3  (~5GB, needs 8GB RAM)
#                 or ollama pull llava:13b      (~8GB, needs 12GB RAM)
#                 or ollama pull llava          (~4.7GB, basic)
#
# NOTE: Auto-detection order if VISION_PROVIDER is not set:
#   google → gemini → ollama → openai
# ═══════════════════════════════════════════════════════════

# ─── LLM Provider (for NLP/medicine extraction) ────────────
# Choose: openai | anthropic | gemini | ollama  (default: ollama if no keys)
MODEL_PROVIDER=ollama

# Vision OCR provider — see options above
# google = best quality | gemini = free+fast | ollama = local | openai = paid
VISION_PROVIDER=ollama

# ─── OpenAI ────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# Override default model (default: gpt-4o)
# OPENAI_MODEL=gpt-4o

# ─── Anthropic (Claude) ────────────────────────────────────
# Required when MODEL_PROVIDER=anthropic or VISION_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
# Override default model (default: claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── Google Cloud Vision (BEST OCR — free 1000/month) ──────
# Required when VISION_PROVIDER=google
# Setup: console.cloud.google.com → Enable Cloud Vision API → Create API Key
# Free tier: 1000 units/month, no billing required
GOOGLE_VISION_API_KEY=AIza...

# ─── Google Gemini (free 1500/day, fast, excellent vision) ──
# Required when MODEL_PROVIDER=gemini or VISION_PROVIDER=gemini
# Free key (no billing): https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...
# Override default model (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# ─── Ollama (Local LLM — No API Key Required) ───────────────
# Required when MODEL_PROVIDER=ollama or VISION_PROVIDER=ollama
# Start Ollama: `ollama serve` then pull models (see Quick Setup above)
OLLAMA_ENDPOINT=http://127.0.0.1:11434
# Text/NLP model for medicine extraction (default: llama3.2)
# OLLAMA_MODEL=llama3.2
#
# Vision model for prescription image OCR — VISION IS NOW PRIMARY ENGINE
# Recommended (best handwriting quality):
#   OLLAMA_VISION_MODEL=llava-llama3   ← best results, ~5GB
#   OLLAMA_VISION_MODEL=llava:13b      ← high quality, ~8GB
#   OLLAMA_VISION_MODEL=llava          ← basic, ~4.7GB (default)
#   OLLAMA_VISION_MODEL=moondream      ← lightweight, ~1.8GB
# OLLAMA_VISION_MODEL=llava
#
# Legacy flag (still works — sets MODEL_PROVIDER=ollama automatically)
# USE_LOCAL_LLM=true

# ─── Supabase ──────────────────────────────────────────────
# Free tier available at: https://supabase.com
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# ─── OCR Configuration ────────────────────────────────────
OCR_MIN_CONSENSUS_PASSES=2
OCR_MIN_CONFIDENCE_SCORE=40

# ─── CORS ─────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Notes ────────────────────────────────────────────────
# Embeddings use OpenAI (text-embedding-3-small) for Stage 3 vector search.
# Without OPENAI_API_KEY, Stage 3 is skipped gracefully — Stages 1, 2, and 4
# continue to work. To rebuild the vector DB with a different embedding model,
# update embeddingService.js and re-run: npm run embeddings

# Production infrastructure additions
NODE_ENV=development
APP_VERSION=1.1.0
SERVICE_NAME=vaidyadrishti-backend
LOG_LEVEL=info
JWT_ISSUER=vaidyadrishti-backend
JWT_AUDIENCE=vaidyadrishti-api
JWT_TOKEN_TTL_SECONDS=43200
JWT_MAX_TOKEN_AGE_SECONDS=43200

REDIS_URL=redis://127.0.0.1:6379
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_PUBLIC_MAX=120
RATE_LIMIT_TENANT_MAX=300
RATE_LIMIT_IP_MAX=180
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_AUTH_FAIL_MAX=10
GLOBAL_REQUEST_TIMEOUT_MS=45000

WORKER_CONCURRENCY=2
JOB_MAX_ATTEMPTS=2
JOB_BACKOFF_MS=2000

# Observability
DB_SLOW_QUERY_MS=500
RESOURCE_MONITOR_INTERVAL_MS=30000
RESOURCE_HEAP_WARN_MB=1024
RESOURCE_RSS_WARN_MB=1536
EVENT_LOOP_DELAY_WARN_MS=200
METRICS_SNAPSHOT_CACHE_MS=1000

# Performance tuning
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONN_TIMEOUT_MS=5000
# WORKER_CONCURRENCY controls worker parallelism
# RATE_LIMIT_PUBLIC_MAX and RATE_LIMIT_TENANT_MAX control traffic shaping

# Load testing (non-production only)
LOAD_BASE_URL=http://127.0.0.1:3001
LOAD_CONCURRENCY_LEVELS=10,50,100,200
LOAD_DURATION_SEC=20
LOAD_PIPELINING=1
LOAD_JWT_TOKEN=
LOAD_TEST_ALLOW_PROD=false
DB_POOL_MIN=2
DB_STATEMENT_TIMEOUT_MS=8000
DB_IDLE_TX_TIMEOUT_MS=10000
DB_LOCK_TIMEOUT_MS=3000
REDIS_CONNECT_TIMEOUT_MS=5000
REDIS_RETRY_BASE_MS=200
REDIS_RETRY_MAX_MS=2000
RATE_LIMIT_TIMEOUT_MS=800
COMPRESSION_THRESHOLD_BYTES=1024
REQUEST_BODY_LIMIT_BYTES=26214400
URLENCODED_BODY_LIMIT_BYTES=1048576
MAX_TEXT_INPUT_LEN=20000
MAX_IMAGE_BASE64_LEN=15000000
ERROR_TRACKER_PROVIDER=none
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0
BILLING_PROVIDER=disabled
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_TIMEOUT_MS=10000
BILLING_MONTHLY_QUOTA_FREE=500
BILLING_MONTHLY_QUOTA_PRO=5000
BILLING_MONTHLY_QUOTA_ENTERPRISE=50000
