# ─── Server ────────────────────────────────────────────────
PORT=3001

# ═══════════════════════════════════════════════════════════
# QUICK SETUP — NO API KEYS (100% Local with Ollama)
# ═══════════════════════════════════════════════════════════
# 1. Install Ollama: https://ollama.com/download
# 2. Run: ollama serve
# 3. Pull models:
#      ollama pull llama3.2        (text / NLP extraction)
#      ollama pull llava           (vision OCR for handwritten prescriptions)
# 4. Copy this file to .env and set:
#      MODEL_PROVIDER=ollama
#      VISION_PROVIDER=ollama
#      OLLAMA_MODEL=llama3.2
#      OLLAMA_VISION_MODEL=llava
# 5. Add your Supabase keys (free tier available at supabase.com)
# Note: Without OPENAI_API_KEY, Stage 3 vector search is skipped
# automatically. Stages 1, 2, and 4 (Ollama) still work fully.
# ═══════════════════════════════════════════════════════════

# ─── LLM Provider ──────────────────────────────────────────
# Choose: openai | anthropic | gemini | ollama  (default: openai)
MODEL_PROVIDER=openai

# Vision OCR provider (default: same as MODEL_PROVIDER, falls back to openai)
# Supported: openai | anthropic | gemini | ollama
VISION_PROVIDER=openai

# ─── OpenAI ────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# Override default model (default: gpt-4o)
# OPENAI_MODEL=gpt-4o

# ─── Anthropic (Claude) ────────────────────────────────────
# Required when MODEL_PROVIDER=anthropic or VISION_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
# Override default model (default: claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── Google Gemini ─────────────────────────────────────────
# Required when MODEL_PROVIDER=gemini or VISION_PROVIDER=gemini
GEMINI_API_KEY=AIza...
# Override default model (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# ─── Ollama (Local LLM — No API Key Required) ───────────────
# Required when MODEL_PROVIDER=ollama or VISION_PROVIDER=ollama
# Start Ollama: `ollama serve` then pull models (see Quick Setup above)
OLLAMA_ENDPOINT=http://127.0.0.1:11434
# Text/NLP model (default: llama3.2)
# OLLAMA_MODEL=llama3.2
# Vision model for OCR fallback (default: llava)
# OLLAMA_VISION_MODEL=llava
# Other good vision models: bakllava, moondream, minicpm-v
# Legacy flag (still works — sets MODEL_PROVIDER=ollama automatically)
# USE_LOCAL_LLM=true

# ─── Supabase ──────────────────────────────────────────────
# Free tier available at: https://supabase.com
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# ─── OCR Configuration ────────────────────────────────────
OCR_MIN_CONSENSUS_PASSES=2
OCR_MIN_CONFIDENCE_SCORE=40

# ─── CORS ─────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Notes ────────────────────────────────────────────────
# Embeddings use OpenAI (text-embedding-3-small) for Stage 3 vector search.
# Without OPENAI_API_KEY, Stage 3 is skipped gracefully — Stages 1, 2, and 4
# continue to work. To rebuild the vector DB with a different embedding model,
# update embeddingService.js and re-run: npm run embeddings
