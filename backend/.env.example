# ─── Server ────────────────────────────────────────────────
PORT=3001

# ═══════════════════════════════════════════════════════════
# QUICK SETUP — NO API KEYS (100% Local with Ollama)
# ═══════════════════════════════════════════════════════════
# 1. Install Ollama: https://ollama.com/download
# 2. Run: ollama serve
# 3. Pull models:
#      ollama pull llama3.2        (text / NLP extraction — ~2GB)
#
#      VISION MODEL — pick ONE based on your RAM:
#      ollama pull llava-llama3    ★ BEST quality  (~5GB, needs 8GB RAM)
#      ollama pull llava:13b       ★ High quality  (~8GB, needs 12GB RAM)
#      ollama pull llava           ✓ Basic quality (~4.7GB, needs 6GB RAM)
#      ollama pull moondream       ✓ Lightweight   (~1.8GB, needs 4GB RAM)
#
# 4. Copy this file to .env and set MODEL_PROVIDER + VISION_PROVIDER + OLLAMA_VISION_MODEL
# 5. Add your Supabase keys (optional — free tier at supabase.com)
# Note: Without OPENAI_API_KEY, Stage 3 vector search is skipped
# automatically. Stages 0, 1, 2, and 4 (Ollama) still work fully.
# ═══════════════════════════════════════════════════════════

# ─── LLM Provider ──────────────────────────────────────────
# Choose: openai | anthropic | gemini | ollama  (default: openai)
MODEL_PROVIDER=openai

# Vision OCR provider (default: same as MODEL_PROVIDER, falls back to openai)
# Supported: openai | anthropic | gemini | ollama
VISION_PROVIDER=openai

# ─── OpenAI ────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# Override default model (default: gpt-4o)
# OPENAI_MODEL=gpt-4o

# ─── Anthropic (Claude) ────────────────────────────────────
# Required when MODEL_PROVIDER=anthropic or VISION_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
# Override default model (default: claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── Google Gemini ─────────────────────────────────────────
# Required when MODEL_PROVIDER=gemini or VISION_PROVIDER=gemini
GEMINI_API_KEY=AIza...
# Override default model (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# ─── Ollama (Local LLM — No API Key Required) ───────────────
# Required when MODEL_PROVIDER=ollama or VISION_PROVIDER=ollama
# Start Ollama: `ollama serve` then pull models (see Quick Setup above)
OLLAMA_ENDPOINT=http://127.0.0.1:11434
# Text/NLP model for medicine extraction (default: llama3.2)
# OLLAMA_MODEL=llama3.2
#
# Vision model for prescription image OCR — VISION IS NOW PRIMARY ENGINE
# Recommended (best handwriting quality):
#   OLLAMA_VISION_MODEL=llava-llama3   ← best results, ~5GB
#   OLLAMA_VISION_MODEL=llava:13b      ← high quality, ~8GB
#   OLLAMA_VISION_MODEL=llava          ← basic, ~4.7GB (default)
#   OLLAMA_VISION_MODEL=moondream      ← lightweight, ~1.8GB
# OLLAMA_VISION_MODEL=llava
#
# Legacy flag (still works — sets MODEL_PROVIDER=ollama automatically)
# USE_LOCAL_LLM=true

# ─── Supabase ──────────────────────────────────────────────
# Free tier available at: https://supabase.com
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# ─── OCR Configuration ────────────────────────────────────
OCR_MIN_CONSENSUS_PASSES=2
OCR_MIN_CONFIDENCE_SCORE=40

# ─── CORS ─────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Notes ────────────────────────────────────────────────
# Embeddings use OpenAI (text-embedding-3-small) for Stage 3 vector search.
# Without OPENAI_API_KEY, Stage 3 is skipped gracefully — Stages 1, 2, and 4
# continue to work. To rebuild the vector DB with a different embedding model,
# update embeddingService.js and re-run: npm run embeddings
